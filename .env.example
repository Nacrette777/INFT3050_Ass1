# ===============================================================
# INFT3050 — front-end environment variables
# Copy this file to ".env.local" (git-ignored) before running.
# ===============================================================

# ---------------------------------------------------------------
# Backend API (auth proxy). Used by src/services/apiClient.js.
# All database traffic goes through port 3001, NOT NocoDB on 8080.
# The auth container injects the xc-token header server-side, so no
# API token is needed in the browser.
# ---------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001


# ---------------------------------------------------------------
# LEGACY — used only by src/services/nocoDbService.js (employee pages).
#
# ⚠️ SECURITY NOTE FOR THE TEAM:
# Anything prefixed VITE_ is compiled into the JavaScript bundle and is
# readable by anyone who opens DevTools. Putting the NocoDB API token
# here exposes it. These pages should be migrated to apiClient.js, which
# routes through the auth proxy and never sees the token.
# Left in place so the employee pages keep working — do not delete
# without talking to whoever owns that module.
# ---------------------------------------------------------------
VITE_NOCODB_BASE_URL=http://localhost:8080
VITE_NOCODB_BASE_ID=your_base_id
VITE_NOCODB_USERS_TABLE_ID=your_users_table_id
VITE_NOCODB_PRODUCTS_TABLE_ID=your_products_table_id
VITE_NOCODB_TOKEN=your_nocodb_api_token
